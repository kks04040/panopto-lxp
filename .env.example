PORT=3000
SESSION_SECRET=kyunyang-lxp-secret-change-this

# Panopto 서버 설정
PANOPTO_SERVER=dunet.ap.panopto.com

# Panopto OAuth2 클라이언트 (파놉토 관리자에서 발급)
# System > Identity Providers > Add Panopto OAuth2 Client
PANOPTO_CLIENT_ID=your-client-id-here
PANOPTO_CLIENT_SECRET=your-client-secret-here

# 출석 인정 기준 (0.0 ~ 1.0)
ATTENDANCE_THRESHOLD=0.80

# 폴링 주기 (초) - 파놉토 API 호출 간격
POLLING_INTERVAL_SEC=30
